{
  "name": "copillm",
  "version": "0.2.0",
  "description": "Local Copilot proxy CLI (OpenAI/Anthropic-compatible)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "copillm": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcjc-dev/copillm.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "test": "vitest run",
    "test:e2e:pr": "npm run build && tsx tests/e2e/pr-gate-runner.ts",
    "test:e2e:release": "npm run build && tsx tests/e2e/release-runner.ts",
    "start": "node dist/cli.js",
    "prepack": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "keytar": "^7.9.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "smol-toml": "^1.6.1",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
