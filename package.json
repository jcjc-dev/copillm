{
  "name": "copillm",
  "version": "0.3.0-beta.3",
  "description": "Local Copilot proxy CLI (OpenAI/Anthropic-compatible)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "copillm": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jcjc-dev/copillm.git"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "dev:start": "npm run build && node dist/cli.js --dev start",
    "dev:stop": "npm run build && node dist/cli.js --dev stop",
    "dev:status": "node dist/cli.js --dev status",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.tests.json --noEmit && eslint src",
    "lint:boundaries": "eslint src",
    "test": "vitest run",
    "test:e2e:pr": "npm run build && tsx tests/e2e/pr-gate-runner.ts",
    "test:e2e:release": "npm run build && tsx tests/e2e/release-runner.ts",
    "start": "node dist/cli.js",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0",
    "commander": "^12.1.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "smol-toml": "^1.6.1",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
